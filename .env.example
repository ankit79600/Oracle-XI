# Football data source (https://www.football-data.org — free tier, 10 req/min)
FOOTBALL_DATA_API_KEY=your_key_here

# ── Wallet keys ──────────────────────────────────────────────────────────────
# Payer wallet — used by the MCP server to sign x402 USDC authorizations (no gas needed)
# Never commit; rotate immediately if leaked
PRIVATE_KEY=your_private_key_hex_here

# Facilitator wallet — used by the Oracle API server to submit x402 payments on-chain
# Must hold testnet INJ for gas. Can be the same as PRIVATE_KEY for demos.
X402_FACILITATOR_KEY=your_facilitator_key_hex_here

# ── Injective EVM Testnet ────────────────────────────────────────────────────
RPC_URL=https://k8s.testnet.json-rpc.injective.network/
CHAIN_ID=1439

# ── x402 payment config ──────────────────────────────────────────────────────
# IMPORTANT: x402 requires EIP-3009 tokens. USDT on Injective does NOT support
# EIP-3009. Use USDC (Circle FiatTokenV2_2). Get testnet USDC at faucet.circle.com.
#
# Default: testnet USDC on Injective EVM testnet (Circle FiatTokenV2_2)
X402_TOKEN_ADDRESS=0x0C382e685bbeeFE5d3d9C29e29E341fEE8E84C5d
# Amount in USDC smallest units (6 decimals). 10000 = 0.01 USDC
X402_PRICE=10000
# Oracle treasury wallet that RECEIVES prediction payments (the payTo address)
# For demos you can use your own wallet address (0x126fF3...)
X402_RECIPIENT=0xYOUR_TREASURY_WALLET_HERE

# ── LLM ─────────────────────────────────────────────────────────────────────
# Anthropic Claude — used for the predict tool's reasoning
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── Oracle API server ────────────────────────────────────────────────────────
API_PORT=3002

# Set to true to use mock football data (no API key needed, no rate limits)
# The predict tool still uses real x402 payments and LLM calls.
USE_MOCK_DATA=false

# Set to true to skip on-chain settlement (full x402 handshake still runs).
# Use when the Injective EVM testnet sequencer is not processing transactions.
DEMO_MODE=false
